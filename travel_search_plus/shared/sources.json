{
  "transport": [
    {
      "id": "flight_compare",
      "title_ja": "航空券比較",
      "title_en": "Flight Compare",
      "description_ja": "航空券・LCC・直行便を横断検索。国内と海外の両方に対応。",
      "description_en": "Compare flights, LCCs and direct routes across major booking sites.",
      "providers": [
        {
          "name": "Skyscanner",
          "region": "both",
          "url": "https://www.skyscanner.jp/transport/flights/{origin_air}/{dest_air}/{depart}/{return}/?adultsv2={adults}&childrenv2={children}&cabinclass=economy"
        },
        {
          "name": "Google Flights",
          "region": "both",
          "url": "https://www.google.com/travel/flights?q=Flights%20to%20{dest_query}%20from%20{origin_query}%20on%20{depart}%20through%20{return}%20for%20{adults}%20adult"
        },
        {
          "name": "Trip.com",
          "region": "both",
          "url": "https://www.trip.com/flights/showfarefirst?dcity={origin_air}&acity={dest_air}&ddate={depart}&rdate={return}&triptype=rt&class=y&quantity={adults}"
        },
        {
          "name": "Expedia",
          "region": "both",
          "url": "https://www.expedia.co.jp/Flights-Search?trip=roundtrip&leg1=from:{origin_query},to:{dest_query},departure:{depart}TANYT&leg2=from:{dest_query},to:{origin_query},departure:{return}TANYT&adults={adults}&children={children}&infants=0&cabinclass=economy"
        }
      ]
    },
    {
